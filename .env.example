# HackerLabAcademy Docker Environment

# ========================
# AI Provider Selection
# ========================
# Options: "gemini", "ollama", "auto"
# - "gemini": uses Google Gemini API (requires GEMINI_API_KEY)
# - "ollama": uses local Ollama server (requires Ollama running)
# - "auto": tries Gemini first, falls back to Ollama if Gemini fails
AI_PROVIDER=gemini

# ========================
# Gemini (Cloud) Config
# ========================
# Required if AI_PROVIDER=gemini or AI_PROVIDER=auto
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================
# Ollama (Local) Config
# ========================
# Only needed if AI_PROVIDER=ollama or AI_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
# Model must be already pulled in Ollama: `ollama pull <model>`
OLLAMA_MODEL=llama3

# ========================
# Other Settings
# ========================
# Enable daily CVE auto-fetch (true/false)
CVE_SCHEDULED_FETCH=false
